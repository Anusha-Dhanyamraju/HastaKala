<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/divider_color"
    app:cardBackgroundColor="@color/surface_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="18dp"
        android:paddingVertical="14dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_log_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Banana Bag - Red (x2)"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_log_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 Apr 2026, 14:30"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_log_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹ 450"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:paddingHorizontal="12dp" />

        <ImageButton
            android:id="@+id/btn_delete_log"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/stock_critical" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
